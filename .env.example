# Alpha DFS AI — Provider credentials (Task 11.5)
# Copy to .env.local and configure for live data ingestion.

# DraftKings P0 — file export (recommended v1)
DRAFTKINGS_EXPORT_PATH=/absolute/path/to/draftkings-classic-export.json

# DraftKings P0 — REST API (optional)
# DRAFTKINGS_API_URL=https://api.example.com/v1/slate
# DRAFTKINGS_API_KEY=your-api-key

# Projection P1 — file export
PROJECTION_EXPORT_PATH=/absolute/path/to/projection-export.json

# Projection P1 — REST API (optional)
# PROJECTION_API_URL=https://api.example.com/v1/projections
# PROJECTION_API_KEY=your-api-key

# Injury P1 — file export
INJURY_EXPORT_PATH=/absolute/path/to/injury-export.json

# Injury P1 — REST API (optional)
# INJURY_API_URL=https://api.example.com/v1/injuries
# INJURY_API_KEY=your-api-key

# Vegas odds P1 — file export
VEGAS_ODDS_EXPORT_PATH=/absolute/path/to/vegas-odds-export.json

# Vegas odds P1 — REST API (optional)
# VEGAS_ODDS_API_URL=https://api.example.com/v1/odds
# VEGAS_ODDS_API_KEY=your-api-key

# Weather P2 — file export (optional enrichment)
WEATHER_EXPORT_PATH=/absolute/path/to/weather-export.json

# Weather P2 — REST API (optional)
# WEATHER_API_URL=https://api.example.com/v1/weather
# WEATHER_API_KEY=your-api-key

# Optional: surface P2 connector failures in degraded refresh flag
# CONNECTOR_P2_VISIBILITY=1

# Connector mode: live (default) or seed (dev fallback without credentials)
# CONNECTOR_MODE=live

# Database — use absolute path in production (Prisma resolves relative paths from schema location)
DATABASE_URL=file:/absolute/path/to/alpha-dfs.db

# Engine mode: real (default) or stub
# ENGINE_REGISTRY_MODE=real

# GPP field simulation (V2.1-3 — ADR-012 defaults)
# SIMULATION_FIELD_SIZE=10000
# SIMULATION_COUNT=10000

# Projection calibration (V2.1-7 — ADR-016; default off preserves V1 path)
# PROJECTION_CALIBRATION_ENABLED=true

# Observability & resilience (Task 11.6 — defaults shown)
# PIPELINE_TIMEOUT_MS=120000
# CONNECTOR_TIMEOUT_MS=15000
# PROVIDER_HTTP_TIMEOUT_MS=15000
# CONNECTOR_MAX_RETRIES=3
# CONNECTOR_RETRY_BASE_MS=250
# CIRCUIT_BREAKER_THRESHOLD=5
# CIRCUIT_BREAKER_RESET_MS=60000
# FRESHNESS_THRESHOLD_MS=86400000
# METRICS_RETENTION_COUNT=500
# TRACE_RETENTION_COUNT=100
# LOG_RETENTION_COUNT=100

# External telemetry export (V2.0-1 — default off)
# TELEMETRY_EXPORT_MODE=none
# TELEMETRY_EXPORT_MODE=file
# TELEMETRY_EXPORT_PATH=/absolute/path/to/telemetry.jsonl
# TELEMETRY_EXPORT_INTERVAL_MS=30000
# TELEMETRY_EXPORT_MODE=otlp
# TELEMETRY_EXPORT_OTLP_ENDPOINT=https://otel.example/v1/logs
# TELEMETRY_EXPORT_OTLP_HEADERS={"Authorization":"Bearer token"}

# Seed fallback (dev/test only — disabled in production by default)
# CONNECTOR_MODE=seed
# ALPHA_DFS_ALLOW_SEED_FALLBACK=true

# ADI Platform (V2.2 — default off preserves V2.1 behavior)
# ADI_PLATFORM_ENABLED=false
# ADI_FUSION_ENABLED=true
# ADI_PROVIDER_NEWS_ENABLED=false
# ADI_PROVIDER_SOCIAL_ENABLED=false
# ADI_PROVIDER_SPORTSBOOK_ENABLED=false
# ADI_PROVIDER_CONSENSUS_ENABLED=false
# ADI_PROVIDER_DFS_CONTENT_ENABLED=false
# ADI_PROVIDER_BETTING_ENABLED=false
# ADI_PROVIDER_HISTORICAL_LEARNING_ENABLED=false
